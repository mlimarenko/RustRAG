{
  "openapi": "3.1.0",
  "info": {
    "title": "Inventory Management API",
    "version": "2.3.0",
    "description": "REST API for managing warehouse inventory, stock levels, purchase orders, and supplier relationships. Supports multi-warehouse operations with real-time stock synchronization.",
    "contact": {
      "name": "Platform Engineering Team",
      "email": "platform@example.com"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    }
  },
  "servers": [
    {
      "url": "https://api.inventory.example.com/v2",
      "description": "Production"
    },
    {
      "url": "https://staging-api.inventory.example.com/v2",
      "description": "Staging"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List products with filtering and pagination",
        "description": "Returns a paginated list of products. Supports filtering by category, status, warehouse, and price range. Results are sorted by name ascending by default.",
        "tags": ["Products"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 },
            "description": "Page number (1-based)"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 },
            "description": "Items per page (max 100)"
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by product category slug"
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["active", "discontinued", "draft"] },
            "description": "Filter by product status"
          },
          {
            "name": "warehouse_id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "description": "Filter by warehouse availability"
          },
          {
            "name": "min_price",
            "in": "query",
            "schema": { "type": "number", "minimum": 0 },
            "description": "Minimum unit price filter"
          },
          {
            "name": "max_price",
            "in": "query",
            "schema": { "type": "number", "minimum": 0 },
            "description": "Maximum unit price filter"
          },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string", "minLength": 2 },
            "description": "Full-text search across name, SKU, and description"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["name", "-name", "price", "-price", "created_at", "-created_at", "stock_level", "-stock_level"], "default": "name" },
            "description": "Sort field (prefix with - for descending)"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated product list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      },
      "post": {
        "operationId": "createProduct",
        "summary": "Create a new product",
        "description": "Creates a new product in draft status. The product must be activated separately via PATCH /products/{id}/activate before it appears in stock queries.",
        "tags": ["Products"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProductRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": {
            "description": "SKU already exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/products/{productId}": {
      "get": {
        "operationId": "getProduct",
        "summary": "Get product details",
        "tags": ["Products"],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Product details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/products/{productId}/stock": {
      "get": {
        "operationId": "getProductStock",
        "summary": "Get stock levels across all warehouses",
        "description": "Returns current stock levels for a product across all warehouses. Includes reserved quantities (allocated to pending orders) and available quantities (total minus reserved).",
        "tags": ["Stock"],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Stock levels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "product_id": { "type": "string", "format": "uuid" },
                    "total_stock": { "type": "integer" },
                    "total_reserved": { "type": "integer" },
                    "total_available": { "type": "integer" },
                    "warehouses": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WarehouseStock" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "adjustStock",
        "summary": "Adjust stock level for a product in a warehouse",
        "description": "Creates a stock adjustment record. Positive quantities increase stock (receiving), negative quantities decrease stock (damage, loss, correction). All adjustments require a reason code and are immutably logged for audit.",
        "tags": ["Stock"],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["warehouse_id", "quantity", "reason_code"],
                "properties": {
                  "warehouse_id": { "type": "string", "format": "uuid" },
                  "quantity": {
                    "type": "integer",
                    "description": "Positive for increase, negative for decrease"
                  },
                  "reason_code": {
                    "type": "string",
                    "enum": ["receiving", "return", "damage", "loss", "correction", "transfer_in", "transfer_out"],
                    "description": "Reason for the stock adjustment"
                  },
                  "reference": {
                    "type": "string",
                    "description": "External reference (PO number, transfer ID, etc.)"
                  },
                  "notes": {
                    "type": "string",
                    "maxLength": 500
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Stock adjusted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StockAdjustment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "422": {
            "description": "Insufficient stock for negative adjustment"
          }
        }
      }
    },
    "/purchase-orders": {
      "post": {
        "operationId": "createPurchaseOrder",
        "summary": "Create a purchase order",
        "description": "Creates a new purchase order for a supplier. The order starts in 'draft' status and must be submitted via PATCH /purchase-orders/{id}/submit. Expected delivery date must be at least 3 business days from submission.",
        "tags": ["Purchase Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePurchaseOrderRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Purchase order created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PurchaseOrder" }
              }
            }
          }
        }
      }
    },
    "/webhooks": {
      "post": {
        "operationId": "registerWebhook",
        "summary": "Register a webhook endpoint",
        "description": "Registers a URL to receive event notifications. Supported events: stock.low (stock below reorder point), stock.adjusted, order.created, order.received, product.created, product.discontinued. Webhook payloads are signed with HMAC-SHA256 using the returned secret.",
        "tags": ["Webhooks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url", "events"],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "HTTPS endpoint to receive events"
                  },
                  "events": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["stock.low", "stock.adjusted", "order.created", "order.received", "product.created", "product.discontinued"]
                    },
                    "minItems": 1
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 200
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "url": { "type": "string" },
                    "events": { "type": "array", "items": { "type": "string" } },
                    "secret": {
                      "type": "string",
                      "description": "HMAC-SHA256 signing secret (shown only once)"
                    },
                    "created_at": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token obtained from POST /auth/token. Include as: Authorization: Bearer <token>"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "sku": { "type": "string", "pattern": "^[A-Z0-9-]{4,20}$" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "unit_price": { "type": "number", "format": "decimal" },
          "currency": { "type": "string", "default": "USD" },
          "weight_kg": { "type": "number" },
          "dimensions": {
            "type": "object",
            "properties": {
              "length_cm": { "type": "number" },
              "width_cm": { "type": "number" },
              "height_cm": { "type": "number" }
            }
          },
          "status": { "type": "string", "enum": ["active", "discontinued", "draft"] },
          "reorder_point": { "type": "integer", "description": "Stock level that triggers reorder alert" },
          "reorder_quantity": { "type": "integer", "description": "Suggested quantity for reorder" },
          "supplier_id": { "type": "string", "format": "uuid" },
          "barcode": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total": { "type": "integer" },
          "total_pages": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid authentication token",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "ValidationError": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded. Retry after the duration in Retry-After header.",
        "headers": {
          "Retry-After": {
            "schema": { "type": "integer" },
            "description": "Seconds to wait before retrying"
          },
          "X-RateLimit-Limit": {
            "schema": { "type": "integer" },
            "description": "Maximum requests per window"
          },
          "X-RateLimit-Remaining": {
            "schema": { "type": "integer" },
            "description": "Remaining requests in current window"
          }
        }
      }
    }
  }
}
