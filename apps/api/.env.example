## Canonical application config reference.
## For Docker Compose, copy `./.env.example` to `./.env`.
## For direct API/worker runs, export values from this file.
## Use only canonical `RUSTRAG_*` variables; lower-case aliases are not supported.

RUSTRAG_BIND_ADDR=0.0.0.0:8080
RUSTRAG_SERVICE_ROLE=all
# Stable process identity used in logs, worker leases and recovery audit.
# Use only ASCII letters, digits, '.', '_' or '-'.
RUSTRAG_SERVICE_NAME=rustrag-backend
RUSTRAG_ENVIRONMENT=local
RUSTRAG_DATABASE_URL=postgres://postgres:postgres@postgres:5432/rustrag
RUSTRAG_DATABASE_MAX_CONNECTIONS=20
RUSTRAG_REDIS_URL=redis://redis:6379
RUSTRAG_ARANGODB_URL=http://arangodb:8529
RUSTRAG_ARANGODB_DATABASE=rustrag
RUSTRAG_ARANGODB_USERNAME=root
RUSTRAG_ARANGODB_PASSWORD=rustrag-dev
RUSTRAG_ARANGODB_REQUEST_TIMEOUT_SECONDS=15
RUSTRAG_ARANGODB_BOOTSTRAP_COLLECTIONS=true
RUSTRAG_ARANGODB_BOOTSTRAP_VIEWS=true
RUSTRAG_ARANGODB_BOOTSTRAP_GRAPH=true
RUSTRAG_ARANGODB_BOOTSTRAP_VECTOR_INDEXES=true
RUSTRAG_ARANGODB_VECTOR_DIMENSIONS=3072
RUSTRAG_ARANGODB_VECTOR_INDEX_N_LISTS=100
RUSTRAG_ARANGODB_VECTOR_INDEX_DEFAULT_N_PROBE=8
RUSTRAG_ARANGODB_VECTOR_INDEX_TRAINING_ITERATIONS=25
RUSTRAG_LOG_FILTER=info
RUSTRAG_FRONTEND_ORIGIN=http://127.0.0.1:19000,http://localhost:19000
# Optional: OpenAPI server URL = API origin only (paths in spec already include /v1). Example: https://api.example.com
# RUSTRAG_OPENAPI_PUBLIC_ORIGIN=
RUSTRAG_BOOTSTRAP_TOKEN=
RUSTRAG_UI_SESSION_SECRET=local-ui-session-secret
RUSTRAG_UI_DEFAULT_LOCALE=ru
RUSTRAG_CONTENT_STORAGE_ROOT=/var/lib/rustrag/content-storage
# Optional provider secrets for first-run AI bootstrap. When set, the login bootstrap screen can
# reuse them and startup can auto-apply canonical bindings for the default workspace/library.
# RUSTRAG_OPENAI_API_KEY=
# RUSTRAG_DEEPSEEK_API_KEY=
# RUSTRAG_QWEN_API_KEY=
# Optional first-run model defaults. The UI still shows these choices and lets the operator adjust
# them before finishing bootstrap.
# RUSTRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_PROVIDER_KIND=openai
# RUSTRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_MODEL_NAME=gpt-5.4
# RUSTRAG_UI_BOOTSTRAP_EMBED_CHUNK_PROVIDER_KIND=openai
# RUSTRAG_UI_BOOTSTRAP_EMBED_CHUNK_MODEL_NAME=text-embedding-3-large
# RUSTRAG_UI_BOOTSTRAP_QUERY_ANSWER_PROVIDER_KIND=openai
# RUSTRAG_UI_BOOTSTRAP_QUERY_ANSWER_MODEL_NAME=gpt-5.4
# RUSTRAG_UI_BOOTSTRAP_VISION_PROVIDER_KIND=openai
# RUSTRAG_UI_BOOTSTRAP_VISION_MODEL_NAME=gpt-5.4-mini
RUSTRAG_LLM_TRANSPORT_RETRY_ATTEMPTS=3
RUSTRAG_LLM_TRANSPORT_RETRY_BASE_DELAY_MS=250
RUSTRAG_QUERY_INTENT_CACHE_TTL_HOURS=24
RUSTRAG_QUERY_INTENT_CACHE_MAX_ENTRIES_PER_LIBRARY=500
RUSTRAG_QUERY_RERANK_ENABLED=true
RUSTRAG_QUERY_RERANK_CANDIDATE_LIMIT=24
RUSTRAG_QUERY_BALANCED_CONTEXT_ENABLED=true
RUSTRAG_RUNTIME_GRAPH_EXTRACT_RECOVERY_ENABLED=true
RUSTRAG_RUNTIME_GRAPH_EXTRACT_RECOVERY_MAX_ATTEMPTS=2
RUSTRAG_RUNTIME_GRAPH_EXTRACT_RESUME_DOWNGRADE_LEVEL_ONE_AFTER_REPLAYS=3
RUSTRAG_RUNTIME_GRAPH_EXTRACT_RESUME_DOWNGRADE_LEVEL_TWO_AFTER_REPLAYS=5
RUSTRAG_RUNTIME_GRAPH_SUMMARY_REFRESH_BATCH_SIZE=64
RUSTRAG_RUNTIME_GRAPH_TARGETED_RECONCILIATION_ENABLED=true
RUSTRAG_RUNTIME_GRAPH_TARGETED_RECONCILIATION_MAX_TARGETS=128
RUSTRAG_RUNTIME_DOCUMENT_ACTIVITY_FRESHNESS_SECONDS=45
RUSTRAG_RUNTIME_DOCUMENT_STALLED_AFTER_SECONDS=180
RUSTRAG_RUNTIME_GRAPH_FILTER_EMPTY_RELATIONS=true
RUSTRAG_RUNTIME_GRAPH_FILTER_DEGENERATE_SELF_LOOPS=true
RUSTRAG_RUNTIME_GRAPH_CONVERGENCE_WARNING_BACKLOG_THRESHOLD=1
# MCP memory defaults for external agent reads/search. Increase only if clients need wider windows.
RUSTRAG_MCP_MEMORY_DEFAULT_READ_WINDOW_CHARS=12000
RUSTRAG_MCP_MEMORY_MAX_READ_WINDOW_CHARS=50000
RUSTRAG_MCP_MEMORY_DEFAULT_SEARCH_LIMIT=10
RUSTRAG_MCP_MEMORY_MAX_SEARCH_LIMIT=25
# Retention is used by upcoming MCP mutation idempotency receipts.
RUSTRAG_MCP_MEMORY_IDEMPOTENCY_RETENTION_HOURS=72
# Set to false to disable persisted MCP audit writes once audit flow lands.
RUSTRAG_MCP_MEMORY_AUDIT_ENABLED=true
