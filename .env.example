# Docker Compose reads this file from the repository root automatically.
# Keep only canonical RUSTRAG_* variables here; do not mix lower-case aliases.
# docker-compose.yml uses prebuilt Docker Hub images by default.
# docker-compose-local.yml keeps the manual source-build path.

# Published HTTP port for nginx -> UI/API/MCP.
RUSTRAG_PORT=19000

# Core service/storage defaults for local compose.
RUSTRAG_ENVIRONMENT=local-compose
RUSTRAG_POSTGRES_DB=rustrag
RUSTRAG_POSTGRES_USER=postgres
RUSTRAG_POSTGRES_PASSWORD=postgres
RUSTRAG_ARANGODB_PASSWORD=rustrag-dev
RUSTRAG_DATABASE_MAX_CONNECTIONS=20
RUSTRAG_ARANGODB_DATABASE=rustrag
RUSTRAG_ARANGODB_USERNAME=root
RUSTRAG_ARANGODB_REQUEST_TIMEOUT_SECONDS=15
RUSTRAG_LOG_FILTER=info
RUSTRAG_FRONTEND_ORIGIN=http://127.0.0.1:19000,http://localhost:19000,http://127.0.0.1:9000,http://localhost:9000,http://127.0.0.1:3000,http://localhost:3000
RUSTRAG_BOOTSTRAP_TOKEN=bootstrap-local

# Optional first-login bootstrap.
RUSTRAG_UI_BOOTSTRAP_ADMIN_LOGIN=
RUSTRAG_UI_BOOTSTRAP_ADMIN_PASSWORD=
RUSTRAG_UI_BOOTSTRAP_ADMIN_API_TOKEN=

# Optional first-run model defaults.
RUSTRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_PROVIDER_KIND=openai
RUSTRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_MODEL_NAME=gpt-5.4
RUSTRAG_UI_BOOTSTRAP_EMBED_CHUNK_PROVIDER_KIND=openai
RUSTRAG_UI_BOOTSTRAP_EMBED_CHUNK_MODEL_NAME=text-embedding-3-large
RUSTRAG_UI_BOOTSTRAP_QUERY_ANSWER_PROVIDER_KIND=openai
RUSTRAG_UI_BOOTSTRAP_QUERY_ANSWER_MODEL_NAME=gpt-5.4
RUSTRAG_UI_BOOTSTRAP_VISION_PROVIDER_KIND=openai
RUSTRAG_UI_BOOTSTRAP_VISION_MODEL_NAME=gpt-5.4-mini

# Optional provider secrets.
RUSTRAG_OPENAI_API_KEY=
RUSTRAG_DEEPSEEK_API_KEY=
RUSTRAG_QWEN_API_KEY=

# Optional runtime policy controls for operator smoke and intervention drills.
# Example: RUSTRAG_RUNTIME_POLICY_REJECT_TASK_KINDS=query_answer
# Example: RUSTRAG_RUNTIME_POLICY_REJECT_TARGET_KINDS=model_request,final_outcome
# RUSTRAG_RUNTIME_POLICY_REJECT_TASK_KINDS=
# RUSTRAG_RUNTIME_POLICY_REJECT_TARGET_KINDS=

# Optional image overrides for prebuilt or internal deployments.
# RUSTRAG_BACKEND_IMAGE=pipingspace/rustrag-backend:latest
# RUSTRAG_FRONTEND_IMAGE=pipingspace/rustrag-frontend:latest
# RUSTRAG_POSTGRES_IMAGE=postgres:18-alpine
# RUSTRAG_REDIS_IMAGE=redis:8.4
# RUSTRAG_ARANGODB_IMAGE=arangodb:3.12.4
# RUSTRAG_NGINX_IMAGE=nginx:1.28-alpine
# RUSTRAG_BACKEND_PORT=18080
# RUSTRAG_FRONTEND_PORT=13000
